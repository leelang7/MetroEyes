# 서울 열린데이터광장 API 키 (https://data.seoul.go.kr/ 에서 발급)
# 일반 데이터 (citydata_ppltn, CardSubwayStatsNew, SPOP_DAILYSUM_JACHI, 공기질 등)
SEOUL_OPENDATA_API_KEY=

# 도시철도 실시간 도착 (TOPIS / swopenapi) — 별도 신청 키
# data.seoul.go.kr 마이페이지에서 "지하철 실시간 도착정보" 데이터셋 활용신청 후 발급
SEOUL_SUBWAY_ARRIVAL_KEY=

# 버스 도착 (있으면). 서울 열린데이터광장 또는 공공데이터포털(data.go.kr) 발급
SEOUL_BUS_ARRIVAL_KEY=

# Anthropic — LLM 인사이트 모듈 + 폭증 컨텍스트 자연어 요약
# https://console.anthropic.com/  (claude-haiku-4-5 무료 tier 충분)
ANTHROPIC_API_KEY=

# 네이버 검색 비로그인 오픈 API — 인파 폭증 시 "왜 붐비는지" 자동 컨텍스트
# https://developers.naver.com/apps/  → 새 애플리케이션 → 검색(뉴스/블로그) 체크
# 일일 25,000회 무료. 키 없으면 헤드라인 fallback / Claude만으로 동작.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 백엔드
API_HOST=0.0.0.0
API_PORT=8765    # lite_server 기본 포트 (docker compose 와 통일)
LOG_LEVEL=INFO

# 디바이스
DEVICE=cuda  # cuda | cpu | mps

# ─────────────────────────────────────────────
# Docker compose 사용 (.env 자동 로드)
#
#   cp .env.example .env
#   # .env 에서 위 키 값 채우기
#   docker compose up -d
#
# → backend (lite_server --demo) :8765 + frontend http.server :5173 동시 기동.
# 키가 비어 있어도 --demo 모드는 동작 (warm seed + 5분 자동 incident).
# ─────────────────────────────────────────────
